{
  "key": "dictation",
  "id": "dictation",
  "name": "Dictation",
  "version": "0.4.5",
  "minNoctaliaVersion": "4.0.0",
  "author": "Abdul Rafay Shaikh",
  "license": "MIT",
  "repository": "https://github.com/arafays/noctalia-dictation",
  "description": "Local offline dictation with sherpa-onnx two-pass streaming or faster-whisper, Silero VAD noise gating, live overlay, wtype injection, session clipboard.",
  "tags": ["Bar", "Panel", "Productivity", "Audio"],
  "entryPoints": {
    "barWidget": "ui/BarWidget.qml",
    "barWidgetSettings": "ui/BarWidgetSettings.qml",
    "panel": "ui/Panel.qml",
    "settings": "ui/Settings.qml",
    "main": "ui/Main.qml"
  },
  "dependencies": {
    "plugins": []
  },
  "metadata": {
    "defaultSettings": {
      "engine": "auto",
      "sherpaProfile": "auto",
      "sherpaProvider": "auto",
      "fwModel": "small",
      "fwDevice": "auto",
      "fwComputeType": "auto",
      "fwBeamSize": 5,
      "fwTemperature": 0,
      "fwInitialPrompt": "",
      "fwConditionOnPreviousText": true,
      "fwNoSpeechThreshold": 0.6,
      "fwCompressionRatioThreshold": 2.4,
      "fwSilenceRms": 0.01,
      "fwPauseSec": 1.5,
      "fwPartialIntervalSec": 2.5,
      "fwInternalVad": false,
      "sherpaNumThreads": 2,
      "sherpaMinSpeechSec": 0.2,
      "sherpaMinSilenceSec": 0.3,
      "sherpaHangoverSec": 0.35,
      "sherpaEndpointSilence1": 2.4,
      "sherpaEndpointSilence2": 1.2,
      "sherpaMaxActivePaths": 4,
      "language": "auto",
      "recordingTimeout": 0,
      "showOverlay": true,
      "showPartialTranscript": true,
      "autoType": true,
      "stopHotkeyHint": "",
      "overlayCustomPositions": {},
      "vadEnabled": true,
      "vadThreshold": 0.4
    }
  }
}
